    "import math\n",
    "x = int(input(\"enter number of plots\"))\n",
    "count=0\n",
    "for i in range(0,x):\n",
    "    y = int(input(\"enter the area of plot\"))\n",
    "    root = math.isqrt(y)\n",
    "    if root*root==y:\n",
    "        count+=1\n",
    "print(count)"
